# Copier vers .env et remplir les valeurs. Ne JAMAIS commiter .env.

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=matcha
POSTGRES_PASSWORD=changeme
POSTGRES_DB=matcha

# Backend
BACKEND_PORT=3000
SESSION_SECRET=changeme-long-random-string

# SMTP (Mailpit en dev : UI sur http://localhost:8025)
SMTP_HOST=mailpit
SMTP_PORT=1025

# URL publique du site (liens dans les emails)
PUBLIC_URL=http://localhost:8080
